# ─── CaptionCraft Environment Variables ───────────────────────────────────────
# Copy this file to .env and fill in the values.

# ─── Server ─────────────────────────────────────────────────────────────────────
PORT=3000
SESSION_SECRET=                            # REQUIRED — random 32+ char string. Server crashes without this.

# ─── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=                              # PostgreSQL connection string (e.g. postgres://user:pass@host:5432/db)

# ─── OpenRouter AI ──────────────────────────────────────────────────────────────
OR_KEY_1=                                  # Primary OpenRouter API key
OR_KEY_2=                                  # Secondary OpenRouter API key (2-key rotation pool)

# ─── Google OAuth (optional — auth disabled if unset) ───────────────────────────
GOOGLE_CLIENT_ID=                          # Google OAuth client ID
GOOGLE_CLIENT_SECRET=                      # Google OAuth client secret

# ─── Replit (auto-configured in Replit environment) ────────────────────────────
# REPLIT_DOMAINS=                          # Comma-separated Replit domain(s)

# ─── Frontend (Vite) ───────────────────────────────────────────────────────────
VITE_SUPABASE_URL=                         # Supabase project URL
VITE_SUPABASE_ANON_KEY=                    # Supabase anon key
